{
  "name": "dynamic-web-app",
  "version": "1.0.0",
  "description": "A dynamic web application with Node.js, Express, and SQLite.",
  "main": "src/server.js",
  "scripts": {
    "start": "nodemon src/server.js",
    "start:ci": "NODE_ENV=test node src/server.js",
    "start:coverage-server": "nyc --reporter=lcov --reporter=text --reporter=html node src/server.js",
    "start:coverage": "nyc --reporter=lcov --reporter=text --reporter=html node src/server.js",
    "cy:run": "nyc --reporter=lcov --reporter=text --reporter=html npm run cy:run-without-coverage",
    "cy:run-without-coverage": "cypress run",
    "cy:open": "start-server-and-test start http://localhost:3000 \"cypress open\"",
    "cy:run:routing": "NODE_ENV=test start-server-and-test start:ci http://localhost:3000 \"cypress run --spec cypress/e2e/routing.cy.js\"",
    "test:backend": "mocha test/backend.test.js --timeout 10000",
    "coverage": "nyc npm run test:backend",
    "lint": "eslint . --ignore-pattern public/dashboard-app/build/",
    "build:react-app": "cd public/dashboard-app && npm install && npm run build && cd ../.."
  },
  "keywords": [],
  "author": "Gemini",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "cypress": "^14.5.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.5",
    "nodemon": "^3.1.10",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.7",
    "start-server-and-test": "^2.0.4"
  },
  "devDependencies": {
    "chai": "^5.2.1",
    "eslint": "^9.31.0",
    "eslint-plugin-cypress": "^5.1.0",
    "globals": "^16.3.0",
    "mocha": "^11.7.1",
    "nyc": "^17.1.0",
    "sinon": "^21.0.0",
    "supertest": "^7.1.3"
  }
}